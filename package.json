{
  "name": "@rapidset/rapidmcp",
  "version": "0.1.1",
  "description": "Standalone MCP server for RapidKit contracts, docs, and validation workflows",
  "type": "module",
  "main": "./src/index.mjs",
  "bin": {
    "rapidmcp": "./src/index.mjs"
  },
  "scripts": {
    "mcp:start": "node src/index.mjs",
    "mcp:help": "node src/index.mjs --help",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "pack": "pnpm pack",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "pnpm run lint && pnpm run format:check && pnpm run pack:dry-run",
    "release": "changeset publish",
    "release:dry": "changeset status --verbose",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "keywords": [
    "mcp",
    "rapidkit",
    "rapidset"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RapidSet/RapidMCP"
  },
  "bugs": {
    "url": "https://github.com/RapidSet/RapidMCP/issues"
  },
  "homepage": "https://github.com/RapidSet/RapidMCP",
  "license": "MIT",
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.12"
  },
  "packageManager": "pnpm@9.15.1+sha512.1acb565e6193efbebda772702950469150cf12bcc764262e7587e71d19dc98a423dff9536e57ea44c49bdf790ff694e83c27be5faa23d67e0c033b583be4bfcf",
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3"
  }
}
